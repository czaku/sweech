{
  "name": "sweech",
  "version": "0.4.0",
  "description": "AI CLI switcher — isolated profile dirs per provider. Switch between Claude Code, Codex, and 10+ AI providers seamlessly.",
  "main": "dist/index.js",
  "bin": {
    "sweech": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc && npm run build -w apps/dashboard",
    "build:cli": "tsc",
    "postbuild": "chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "lint:cli": "eslint src/cli.ts",
    "test": "jest",
    "test:e2e:dashboard": "npm run build && PROJECT_SCREENSHOT_DIR=${PROJECT_SCREENSHOT_DIR:-$HOME/Desktop/screenshots/sweech} playwright test tests/e2e/*.spec.js --reporter=line",
    "typecheck:dashboard": "tsc --noEmit -p apps/dashboard/tsconfig.json",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "npm run build",
    "postinstall": "node scripts/postinstall.js || true",
    "prepublishOnly": "npm run build && npm test",
    "install-hooks": "bash scripts/install-hooks.sh"
  },
  "keywords": [
    "cli",
    "ai",
    "claude",
    "claude-code",
    "codex",
    "openai",
    "anthropic",
    "profile-switcher",
    "rate-limit",
    "provider",
    "account-manager",
    "multi-account",
    "qwen",
    "minimax",
    "kimi",
    "deepseek",
    "glm",
    "openrouter",
    "coding-assistant",
    "ai-switcher",
    "llm",
    "ollama",
    "lm-studio",
    "local-llm",
    "custom-provider",
    "ai-coding",
    "code-assistant"
  ],
  "files": [
    "dist/",
    "assets/mascot/mascot-full-256.png",
    "assets/dashboard-0.4.0.png",
    "scripts/postinstall.js",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "author": "vykeai",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vykeai/sweech.git"
  },
  "bugs": {
    "url": "https://github.com/vykeai/sweech/issues"
  },
  "homepage": "https://github.com/vykeai/sweech#readme",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "archiver": "^6.0.1",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "inquirer": "^9.2.12",
    "openai": "^6.18.0",
    "unzipper": "^0.10.14"
  },
  "workspaces": [
    "apps/dashboard",
    "packages/vysual-react"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/archiver": "^6.0.2",
    "@types/inquirer": "^9.0.7",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/unzipper": "^0.10.9",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "eslint": "^10.4.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3"
  }
}
