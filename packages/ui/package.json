{
  "name": "@sweech/ui",
  "version": "0.1.0",
  "description": "React UI components for sweech agent sessions — chat, tool calls, approvals, human-in-the-loop",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./themes/*": "./src/themes/*"
  },
  "files": [
    "dist",
    "src/themes"
  ],
  "scripts": {
    "build": "tsc && bun build src/index.ts --outdir dist --external react --external react-dom --external @sweech/engine --format esm --minify-syntax && bun build src/server/index.ts --outdir dist/server --target node --format esm --minify-syntax",
    "dev": "tsc --watch",
    "typecheck": "npm --prefix ../core run build && tsc --noEmit",
    "test": "vitest run",
    "test:regression": "vitest run src/__tests__/regression --reporter=default --reporter=json --outputFile=./coverage/regression-report.json",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@sweech/engine": "file:.yalc/@sweech/engine"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.4.0",
    "vitest": "^4.1.2"
  }
}
